            "homepage": "https://github.com/alirezaMalekei",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6"
    },
    "autoload": {
        "psr-4": {
            "Module\\": "Module/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "suggest": {
        "examples": "See the examples/ directory for demonstration code"
